<svg xmlns="http://www.w3.org/2000/svg" width="400" height="500" viewBox="0 0 400 500">
  <rect width="400" height="500" fill="#ebe7de"/>
  <rect x="20" y="20" width="360" height="460" fill="none" stroke="#d4cfc6" stroke-width="1"/>
  <!-- Abstract ink blot shapes -->
  <ellipse cx="200" cy="200" rx="80" ry="60" fill="none" stroke="#1c1c1a" stroke-width="1.5" opacity="0.6"/>
  <ellipse cx="160" cy="240" rx="50" ry="40" fill="#1c1c1a" opacity="0.08"/>
  <ellipse cx="240" cy="180" rx="40" ry="55" fill="#1c1c1a" opacity="0.06"/>
  <circle cx="150" cy="300" r="30" fill="none" stroke="#1c1c1a" stroke-width="1" opacity="0.4"/>
  <circle cx="260" cy="280" r="20" fill="#1c1c1a" opacity="0.07"/>
  <circle cx="190" cy="350" r="15" fill="none" stroke="#1c1c1a" stroke-width="0.8" opacity="0.5"/>
  <line x1="120" y1="140" x2="280" y2="380" stroke="#1c1c1a" stroke-width="0.5" opacity="0.2"/>
  <text x="200" y="450" text-anchor="middle" font-family="monospace" font-size="11" fill="#706a5e">#abstract</text>
</svg>
