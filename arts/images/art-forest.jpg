<svg xmlns="http://www.w3.org/2000/svg" width="400" height="550" viewBox="0 0 400 550">
  <rect width="400" height="550" fill="#ebe7de"/>
  <!-- Forest path illustration -->
  <!-- Path -->
  <path d="M180 550 L190 350 L200 300 L210 350 L220 550" fill="none" stroke="#8a8070" stroke-width="2" opacity="0.4"/>
  <!-- Trees left side -->
  <line x1="80" y1="550" x2="80" y2="200" stroke="#1c1c1a" stroke-width="3" opacity="0.7"/>
  <path d="M40 250 L80 180 L120 250Z" fill="none" stroke="#1c1c1a" stroke-width="1.5" opacity="0.6"/>
  <path d="M50 300 L80 230 L110 300Z" fill="none" stroke="#1c1c1a" stroke-width="1.5" opacity="0.5"/>
  <!-- Trees right side -->
  <line x1="320" y1="550" x2="320" y2="200" stroke="#1c1c1a" stroke-width="3" opacity="0.7"/>
  <path d="M280 250 L320 180 L360 250Z" fill="none" stroke="#1c1c1a" stroke-width="1.5" opacity="0.6"/>
  <path d="M290 300 L320 230 L350 300Z" fill="none" stroke="#1c1c1a" stroke-width="1.5" opacity="0.5"/>
  <!-- Far trees -->
  <line x1="160" y1="400" x2="160" y2="280" stroke="#1c1c1a" stroke-width="1.5" opacity="0.4"/>
  <path d="M140 300 L160 260 L180 300Z" fill="none" stroke="#1c1c1a" stroke-width="1" opacity="0.35"/>
  <line x1="240" y1="400" x2="240" y2="280" stroke="#1c1c1a" stroke-width="1.5" opacity="0.4"/>
  <path d="M220 300 L240 260 L260 300Z" fill="none" stroke="#1c1c1a" stroke-width="1" opacity="0.35"/>
  <!-- Ground lines -->
  <line x1="0" y1="520" x2="400" y2="520" stroke="#1c1c1a" stroke-width="0.5" opacity="0.2"/>
  <text x="200" y="540" text-anchor="middle" font-family="monospace" font-size="11" fill="#706a5e">#landscape</text>
</svg>
